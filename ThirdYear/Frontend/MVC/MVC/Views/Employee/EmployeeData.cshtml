@using MVC.Models
@model EmployeeHolder

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>EmployeeData</title>
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=edit" />
</head>
<body>
    <script src="~/Scripts/jquery-3.7.1.js"></script>
    <script src="~/Scripts/bootstrap.bundle.js"></script>

    <div class="toast-container position-fixed top-0 start-50 translate-middle-x p-3" id="loadingToast">
        <div class="toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="1000">
            <div class="d-flex">
                <div class="toast-body">
                    Hello, what can I do for you?
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <div class="modal fade" id="emailEditModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content p-3">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Email</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="email" class="form-control" id="emailInput" placeholder="Input a valid email address" required/>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" id="confirmEmailChange">Ok</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="createAccountModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content p-3">
                <div class="modal-header">
                    <h5 class="modal-title">Create a user account for: </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" class="form-control" id="idInput" placeholder="I.D Number" />
                </div>
                <div class="modal-body">
                    <input type="text" class="form-control" id="usernameInput" placeholder="Username" />
                </div>
                <div class="modal-body">
                    <input type="password" class="form-control" id="passwordInput" placeholder="Password" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" id="createAccount">Create</button>
                </div>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <button class="btn btn-primary text-center" 
                    type="button" id="createAcc" 
                    data-bs-toggle="modal" 
                    data-bs-target="#createAccountModal" >
                Create Account
            </button>
        </div>
    </nav>

    <table>
        <tr>
            <th>Employee ID</th>
            <th>Last Name</th>
            <th>First Name</th>
            <th>Gender</th>
            <th>Email</th>
        </tr>
        @foreach (Employee item in Model.employeeHolder)
        {
            <tr>
                <td>
                    <a href="javascript:void(0);" class="employee-link" data-employee-id="@item.employee_id">
                        @Html.DisplayFor(modelItem => item.employee_id)
                    </a>
                </td>
                <td>@Html.DisplayFor(modelItem => item.last_name)</td>
                <td>@Html.DisplayFor(modelItem => item.first_name)</td>
                <td>@Html.DisplayFor(modelItem => item.gender)</td>
                <td>
                    @Html.DisplayFor(modelItem => item.email) <button type="button"
        class="btn btn-link edit-email-btn"
        data-employee-id="@item.employee_id"
        data-bs-toggle="modal"
        data-bs-target="#emailEditModal">
    <span class="material-symbols-outlined">
        edit
    </span>
</button>
                </td>
            </tr>
        }
    </table>

    <script>
        let selectedEmployeeId = null;

        $(document).ready(function () {

            //Create a user account for existing employee
            $("#createAccount").click(function () {
                let button = $(this);
                let id = $("#idInput").val().trim();
                let username = $("#usernameInput").val().trim();
                let password = $("#passwordInput").val().trim();

                if (id === "" ||
                    username === "" ||
                    password === "") {
                    showToast("Required field.");
                    return;
                }
                
                button.prop('disabled', true);
                let originalText = button.text();
                button.text("Processing...");

                $.ajax({
                    url: '@Url.Action("CreateData", "Employee")',
                    type: 'POST',
                    data: {
                        id: id,
                        username: username,
                        password: password
                    },
                    dataType: 'text',

                    success: function () {

                        showToast("Account created successfully!", true);

                        setTimeout(function () {

                            const modalElement = document.getElementById('createAccountModal');
                            const modalInstance = bootstrap.Modal.getInstance(modalElement);

                            if (modalInstance) {
                                modalInstance.hide();
                            }

                            location.reload();

                        }, 1200);
                    },

                    error: function (jqXHR) {

                        showToast(jqXHR.responseText || "Unable to process.");

                        // Restore button
                        button.prop('disabled', false);
                        button.text(originalText);
                    }
                });
            });

            //See single employee data using ID
            $(".employee-link").click(function () {
                var employeeId = $(this).data("employee-id");

                showToast("Loading employee data...");

                // Redirect after toast delay
                setTimeout(function () {
                    var baseUrl = '@Url.Action("EmployeeDetails", "Employee")';
                    window.location.href = baseUrl + '/' + encodeURIComponent(employeeId);
                }, 800);
            });

            $('.edit-email-btn').on('click', function () {
                selectedEmployeeId = $(this).data('employee-id');
                $("#emailInput").val("");
            });

            //Change the email of an existing employee
            $('#confirmEmailChange').off('click').on('click', function () {

                let button = $(this);
                let emailIsValid = $("#emailInput")[0];
                let email = $("#emailInput").val().trim();

                if (email === "") {
                    showToast("Email is required.");
                    return;
                }

                if (!emailIsValid.checkValidity()) {
                    // Shows the browser's default tooltip for invalid emails
                    showToast("Invalid email.");
                    return;
                }
                // Disable button + show loading state
                button.prop('disabled', true);
                let originalText = button.text();
                button.text("Updating...");

                $.ajax({
                    url: '@Url.Action("UpdateData", "Employee")',
                    type: 'PUT',
                    data: {
                        employee_id: selectedEmployeeId,
                        email: email
                    },
                    dataType: 'text',

                    success: function () {

                        showToast("Successfully updated!", true);

                        setTimeout(function () {

                            const modalElement = document.getElementById('emailEditModal');
                            const modalInstance = bootstrap.Modal.getInstance(modalElement);

                            if (modalInstance) {
                                modalInstance.hide();
                            }

                            location.reload();

                        }, 1200);
                    },

                    error: function (jqXHR) {

                        showToast(jqXHR.responseText || "Update failed.");

                        // Restore button
                        button.prop('disabled', false);
                        button.text(originalText);
                    }
                });
            });
        });

        function showToast(message, success = false) {
            $(".toast-body").text(message);
            let toast = new bootstrap.Toast(document.querySelector('.toast'));
            toast.show();
        }
    </script>
</body>
</html>